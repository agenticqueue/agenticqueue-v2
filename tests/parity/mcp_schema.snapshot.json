{
  "jsonrpc": "2.0",
  "id": 1,
  "result": {
    "tools": [
      {
        "name": "health_check",
        "description": "Return current health status with a per-call UTC timestamp. Read-only; safe to call repeatedly.",
        "inputSchema": {
          "properties": {
            "agent_identity": {
              "anyOf": [
                {
                  "maxLength": 200,
                  "pattern": "^$|^[A-Za-z0-9_./:-]+$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Informational caller identity recorded in audit rows; authentication remains the Bearer token."
            }
          },
          "type": "object"
        },
        "outputSchema": {
          "properties": {
            "status": {
              "const": "ok",
              "type": "string"
            },
            "timestamp": {
              "format": "date-time",
              "type": "string"
            }
          },
          "required": [
            "status",
            "timestamp"
          ],
          "type": "object"
        },
        "annotations": {
          "readOnlyHint": true
        },
        "_meta": {
          "_fastmcp": {
            "tags": []
          }
        }
      },
      {
        "name": "get_version",
        "description": "Return the process-stable VersionInfo (version, commit, built_at). Read-only; result is byte-stable per process.",
        "inputSchema": {
          "properties": {
            "agent_identity": {
              "anyOf": [
                {
                  "maxLength": 200,
                  "pattern": "^$|^[A-Za-z0-9_./:-]+$",
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Informational caller identity recorded in audit rows; authentication remains the Bearer token."
            }
          },
          "type": "object"
        },
        "outputSchema": {
          "properties": {
            "version": {
              "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
              "type": "string"
            },
            "commit": {
              "pattern": "^[0-9a-f]{7,12}$",
              "type": "string"
            },
            "built_at": {
              "format": "date-time",
              "type": "string"
            }
          },
          "required": [
            "version",
            "commit",
            "built_at"
          ],
          "type": "object"
        },
        "annotations": {
          "readOnlyHint": true
        },
        "_meta": {
          "_fastmcp": {
            "tags": []
          }
        }
      },
      {
