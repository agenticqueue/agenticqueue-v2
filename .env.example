POSTGRES_PASSWORD=<set-a-local-postgres-password>
DATABASE_URL=postgresql+asyncpg://aq:<set-a-local-postgres-password>@db:5432/aq2
DATABASE_URL_SYNC=postgresql+psycopg://aq:<set-a-local-postgres-password>@db:5432/aq2
AQ_KEY_LOOKUP_SECRET=<set-a-local-random-lookup-secret>
AQ_SESSION_SECRET=<set-a-local-random-session-secret-at-least-32-chars>
AQ_COOKIE_SECURE=false
