{
  "name": "@agenticqueue/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm gen:types && next dev --hostname 0.0.0.0 --port 3000",
    "dev:local": "pnpm gen:types && next dev --hostname 0.0.0.0 --port 3002",
    "build": "pnpm gen:types && next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "start:local": "next start --hostname 0.0.0.0 --port 3002",
    "lint": "pnpm gen:types && eslint .",
    "test:e2e": "playwright test",
    "gen:types": "openapi-typescript ../../tests/parity/openapi.snapshot.json -o app/types/api.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.5.6",
    "openapi-typescript": "^7.6.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
